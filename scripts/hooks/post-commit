#!/bin/sh
# Auto-push to origin after every commit.
# If the push fails (offline, conflict), the commit still stands locally;
# run `git push` (or `git pull --rebase && git push`) manually.

branch=$(git rev-parse --abbrev-ref HEAD)
echo "[post-commit] Pushing $branch to origin..."
git push origin "$branch" 2>&1 || echo "[post-commit] Push failed — run 'git push' manually."
