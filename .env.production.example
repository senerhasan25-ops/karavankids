# Karavankids — PRODUCTION ortam şablonu (Windows Server).
# Bu dosyayı `.env` olarak kopyala ve değerleri doldur.
#
# ============================ EN KRİTİK ============================
# APP_KEY: LOKALDEKİ .env'deki APP_KEY ile BİREBİR AYNI olmalıdır!
# API yetki kodları (api_credentials) bu anahtarla ŞİFRELİ saklanır.
# Farklı bir key ile bu değerler çözülemez → "The payload is invalid"
# hatası ve TÜM Ticimax SOAP çağrıları patlar.
#   • Mevcut sistemi taşıyorsan  → lokaldeki APP_KEY'i buraya kopyala.
#   • Sıfırdan kuruyorsan         → `php artisan key:generate` ile üret,
#                                   sonra panelden API Ayarları'nı yeniden gir.
# ==================================================================

APP_NAME="Karavankids Sync"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://PANEL_DOMAIN

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Veritabanı: SQLite (tek sunucu için yeterli) ---
# database/database.sqlite dosyasını lokalden kopyala. Boş kurulumda
# `php artisan migrate --force` dosyayı oluşturur.
DB_CONNECTION=sqlite

# --- Oturum / Kuyruk / Önbellek (hepsi DB driver — ekstra servis gerekmez) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# NOT: Ticimax endpoint / yetki kodları ve sync ayarları .env'de DEĞİL,
# uygulama içinden yönetilir (API Ayarları + Otomatik Güncelleme sayfaları).
